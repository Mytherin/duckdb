# name: test/sql/aggregate/aggregate_state_export/quantile_export_state.test
# description: Test EXPORT_STATE for quantile/median/mad - the state is a list of the accumulated values
# group: [aggregate_state_export]

# empty input exports a NULL state
query I
SELECT median(i) EXPORT_STATE FROM (SELECT 1 AS i WHERE false) t;
----
NULL

query I
SELECT finalize(median(i) EXPORT_STATE) FROM (SELECT 1 AS i WHERE false) t;
----
NULL

# the state is the list of accumulated values
query I
SELECT (median(i) EXPORT_STATE)::INTEGER[] FROM (VALUES (3), (1), (2)) t(i);
----
[3, 1, 2]

# basic roundtrips
query I
SELECT finalize(median(i) EXPORT_STATE) FROM range(1, 12) t(i);
----
6

query I
SELECT finalize(mad(d) EXPORT_STATE) FROM (VALUES (1.0), (2.0), (10.0)) t(d);
----
1.0

# parameterized quantiles store their serialized bind data in the state type - finalize restores it
query I
SELECT (quantile_disc(i, 0.5) EXPORT_STATE)::BIGINT[] FROM (VALUES (1), (3), (2)) t(i);
----
[1, 3, 2]

query III
SELECT finalize(quantile_disc(i, 0.5) EXPORT_STATE), finalize(quantile_cont(i, 0.25) EXPORT_STATE), finalize(quantile_cont(i, [0.25, 0.75]) EXPORT_STATE)
FROM range(1, 12) t(i);
----
6	3.5	[3.5, 8.5]

# combine_aggr keeps the quantile parameters of the states
query I
SELECT finalize(combine_aggr(s)) FROM (
    SELECT quantile_disc(i, 0.25) EXPORT_STATE AS s FROM range(1, 6) t(i)
    UNION ALL
    SELECT quantile_disc(i, 0.25) EXPORT_STATE AS s FROM range(6, 12) t(i)
) t;
----
3

# strings - both inlined and non-inlined
query I
SELECT finalize(median(v) EXPORT_STATE) FROM (VALUES ('apple'), ('this-is-a-very-long-string-that-is-not-inlined'), ('banana')) t(v);
----
banana

query I
SELECT (median(v) EXPORT_STATE)::VARCHAR[] FROM (VALUES ('apple'), ('this-is-a-very-long-string-that-is-not-inlined')) t(v);
----
[apple, this-is-a-very-long-string-that-is-not-inlined]

# decimals, dates and timestamps
query II
SELECT finalize(median(d) EXPORT_STATE), (median(d) EXPORT_STATE)::DECIMAL(4,1)[] FROM (VALUES (1.5), (4.2), (2.5)) t(d);
----
2.5	[1.5, 4.2, 2.5]

query I
SELECT finalize(mad(d) EXPORT_STATE) FROM (VALUES (DATE '2000-01-01'), (DATE '2000-01-03'), (DATE '2000-01-11')) t(d);
----
2 days

query I
SELECT finalize(median(ts) EXPORT_STATE) FROM (VALUES (TIMESTAMP '2000-01-01 01:00:00'), (TIMESTAMP '2000-01-03 02:00:00')) t(ts);
----
2000-01-02 01:30:00

# large inputs span many segments
query I
SELECT finalize(median(r) EXPORT_STATE) FROM range(1001) t(r);
----
500

# grouped aggregation matches the regular aggregate
statement ok
CREATE TABLE dummy AS SELECT range % 10 g, range d FROM range(100);

query III nosort grouped_quantile
SELECT g, median(d), mad(d::DOUBLE) FROM dummy GROUP BY g ORDER BY g;
----

query III nosort grouped_quantile
SELECT g, finalize(median(d) EXPORT_STATE), finalize(mad(d::DOUBLE) EXPORT_STATE) FROM dummy GROUP BY g ORDER BY g;
----

# we can persist the state and finalize later
statement ok
CREATE TABLE quantile_state AS SELECT g, median(d) EXPORT_STATE m FROM dummy GROUP BY g;

query II nosort grouped_median
SELECT g, median(d) FROM dummy GROUP BY g ORDER BY g;
----

query II nosort grouped_median
SELECT g, finalize(m) FROM quantile_state ORDER BY g;
----

# combine two states
query I
SELECT finalize(combine(median(i) EXPORT_STATE, (SELECT median(j) EXPORT_STATE FROM (VALUES (10), (20)) s(j)))) FROM (VALUES (30)) t(i);
----
20

# combine_aggr across groups
query I
SELECT finalize(combine_aggr(s)) FROM (
    SELECT median(v) EXPORT_STATE AS s FROM (VALUES (1), (2)) t(v)
    UNION ALL
    SELECT median(v) EXPORT_STATE AS s FROM (VALUES (3)) t(v)
    UNION ALL
    SELECT median(v) EXPORT_STATE AS s FROM (SELECT NULL::INTEGER AS v WHERE false) t
) t;
----
2

# to_aggregate_state converts a plain list back into an aggregate state
query I
SELECT finalize(to_aggregate_state([5, 1, 3], 'median', ['INTEGER']));
----
3

query I
SELECT finalize(to_aggregate_state(NULL::INTEGER[], 'median', ['INTEGER']));
----
NULL

# complex types go through the sort key fallback - these cannot be exported
statement error
SELECT median(s) EXPORT_STATE FROM (VALUES ({'a': 1})) t(s);
----
<REGEX>:.*does not have a state type callback.*
