# name: test/sql/aggregate/aggregate_state_export/histogram_export_state.test
# description: Test EXPORT_STATE for histogram and binned histogram/histogram_exact
# group: [aggregate_state_export]

# empty input exports a NULL state
query II
SELECT histogram(i) EXPORT_STATE, finalize(histogram(i) EXPORT_STATE) FROM (SELECT 1 AS i WHERE false) t;
----
NULL	NULL

# the state of histogram is the histogram map itself
query I
SELECT (histogram(x) EXPORT_STATE)::MAP(INTEGER, UBIGINT) FROM (VALUES (1), (2), (2)) t(x);
----
{1=1, 2=2}

# basic roundtrips
query II nosort hist_basic
SELECT histogram(x), histogram(v) FROM (VALUES (1, 'a'), (2, 'this-is-a-long-string-that-is-not-inlined'), (2, 'a')) t(x, v);
----

query II nosort hist_basic
SELECT finalize(histogram(x) EXPORT_STATE), finalize(histogram(v) EXPORT_STATE) FROM (VALUES (1, 'a'), (2, 'this-is-a-long-string-that-is-not-inlined'), (2, 'a')) t(x, v);
----

# types that go through sort keys
query II nosort hist_types
SELECT histogram(d), histogram(l) FROM (VALUES (DATE '2000-01-01', [1, 2]), (DATE '2000-01-01', [1, 2]), (DATE '2010-01-01', [3])) t(d, l);
----

query II nosort hist_types
SELECT finalize(histogram(d) EXPORT_STATE), finalize(histogram(l) EXPORT_STATE) FROM (VALUES (DATE '2000-01-01', [1, 2]), (DATE '2000-01-01', [1, 2]), (DATE '2010-01-01', [3])) t(d, l);
----

# binned histogram - the state holds the (boundary, count) bin entries,
# with the count of the overflow ("other") bucket stored in a separate field
query I
SELECT (histogram(x, [10, 20]) EXPORT_STATE)::STRUCT(histogram STRUCT(boundary INTEGER, count UBIGINT)[], other UBIGINT) FROM (VALUES (5), (15), (25)) t(x);
----
{'histogram': [{'boundary': 10, 'count': 1}, {'boundary': 20, 'count': 1}], 'other': 1}

query II nosort hist_binned
SELECT histogram(x, [10, 20]), histogram_exact(v, ['a']) FROM (VALUES (5, 'a'), (15, 'b'), (25, 'a')) t(x, v);
----

query II nosort hist_binned
SELECT finalize(histogram(x, [10, 20]) EXPORT_STATE), finalize(histogram_exact(v, ['a']) EXPORT_STATE) FROM (VALUES (5, 'a'), (15, 'b'), (25, 'a')) t(x, v);
----

# grouped aggregation matches the regular aggregate
statement ok
CREATE TABLE dummy AS SELECT range % 10 g, range % 3 d FROM range(100);

query III nosort grouped_hist
SELECT g, histogram(d), histogram(d, [1]) FROM dummy GROUP BY g ORDER BY g;
----

query III nosort grouped_hist
SELECT g, finalize(histogram(d) EXPORT_STATE), finalize(histogram(d, [1]) EXPORT_STATE) FROM dummy GROUP BY g ORDER BY g;
----

# we can persist the state and finalize later
statement ok
CREATE TABLE hist_state AS SELECT g, histogram(d) EXPORT_STATE s1, histogram(d, [1]) EXPORT_STATE s2 FROM dummy GROUP BY g;

query III nosort grouped_hist
SELECT g, finalize(s1), finalize(s2) FROM hist_state ORDER BY g;
----

# combine_aggr across groups, including a NULL state
query I
SELECT finalize(combine_aggr(s)) FROM (
    SELECT histogram(x) EXPORT_STATE AS s FROM (VALUES (1), (2)) t(x)
    UNION ALL
    SELECT histogram(x) EXPORT_STATE AS s FROM (VALUES (2), (3)) t(x)
    UNION ALL
    SELECT histogram(x) EXPORT_STATE AS s FROM (SELECT 1 AS x WHERE false) t
) t;
----
{1=1, 2=2, 3=1}

# binned histograms can also be combined
query I
SELECT finalize(combine_aggr(s)) FROM (
    SELECT histogram(x, [10, 20]) EXPORT_STATE AS s FROM (VALUES (5), (15)) t(x)
    UNION ALL
    SELECT histogram(x, [10, 20]) EXPORT_STATE AS s FROM (VALUES (25)) t(x)
) t;
----
{10=1, 20=1, 2147483647=1}

# duplicate bin boundaries are deduplicated -
# the exported state faithfully reproduces the direct result
query II
SELECT finalize(histogram(x, [10, 10, 20]) EXPORT_STATE), histogram(x, [10, 10, 20]) FROM (VALUES (5), (15), (25)) t(x);
----
{10=1, 20=1}	{10=1, 20=1}

# combining binned histograms with different boundaries is an error
statement error
SELECT finalize(combine(histogram(x, [10]) EXPORT_STATE, (SELECT histogram(y, [99]) EXPORT_STATE FROM (VALUES (1)) s(y)))) FROM (VALUES (1)) t(x);
----
<REGEX>:.*cannot combine histograms with different bin boundaries.*

# to_aggregate_state converts a plain map back into a histogram state
query I
SELECT finalize(to_aggregate_state(MAP([1, 2], [3, 4]::UBIGINT[]), 'histogram', ['INTEGER']));
----
{1=3, 2=4}

# the binned histogram state holds the (boundary, count) bin entries and the count of the overflow bucket
query I
SELECT finalize(to_aggregate_state({'histogram': [{'boundary': 10, 'count': 1}, {'boundary': 20, 'count': 1}], 'other': 5}, 'histogram', ['INTEGER', 'INTEGER[]']));
----
{10=1, 20=1, 2147483647=5}
