# name: test/sql/aggregate/aggregate_state_export/reservoir_quantile_export_state.test
# description: Test EXPORT_STATE for reservoir_quantile - the sampled values are explicitly (de)serialized
# group: [aggregate_state_export]

# empty input exports a NULL state
query II
SELECT reservoir_quantile(i, 0.5) EXPORT_STATE, finalize(reservoir_quantile(i, 0.5) EXPORT_STATE) FROM (SELECT 1 AS i WHERE false) t;
----
NULL	NULL

# the state holds the reservoir size and the sampled values
query I
SELECT (reservoir_quantile(i, 0.5, 4) EXPORT_STATE)::STRUCT(sample_size UBIGINT, "values" INTEGER[]) FROM (VALUES (1), (2), (3)) t(i);
----
{'sample_size': 4, 'values': [1, 2, 3]}

# when the sample size is larger than the input the result is exact and round-trips
query II nosort reservoir_exact
SELECT reservoir_quantile(i, 0.5, 2000), reservoir_quantile(i, [0.2, 0.8], 2000) FROM range(1, 1001) t(i);
----

query II nosort reservoir_exact
SELECT finalize(reservoir_quantile(i, 0.5, 2000) EXPORT_STATE), finalize(reservoir_quantile(i, [0.2, 0.8], 2000) EXPORT_STATE) FROM range(1, 1001) t(i);
----

# different types
query IRI
SELECT finalize(reservoir_quantile(i::TINYINT, 0.5, 100) EXPORT_STATE), finalize(reservoir_quantile(i::DOUBLE, 0.5, 100) EXPORT_STATE), finalize(reservoir_quantile(i::HUGEINT, 0.5, 100) EXPORT_STATE) FROM range(1, 12) t(i);
----
6	6	6

query I
SELECT finalize(reservoir_quantile(d, 0.5, 100) EXPORT_STATE) FROM (VALUES (1.5::DECIMAL(4,1)), (4.5::DECIMAL(4,1)), (2.5::DECIMAL(4,1))) t(d);
----
2.5

# grouped aggregation matches the regular aggregate (sample size > group size, so exact)
statement ok
CREATE TABLE dummy AS SELECT range % 10 g, range d FROM range(1000);

query II nosort grouped_reservoir
SELECT g, reservoir_quantile(d, 0.5, 2000) FROM dummy GROUP BY g ORDER BY g;
----

query II nosort grouped_reservoir
SELECT g, finalize(reservoir_quantile(d, 0.5, 2000) EXPORT_STATE) FROM dummy GROUP BY g ORDER BY g;
----

# we can persist the state and finalize later
statement ok
CREATE TABLE reservoir_state AS SELECT g, reservoir_quantile(d, 0.5, 2000) EXPORT_STATE s FROM dummy GROUP BY g;

query II nosort grouped_reservoir
SELECT g, finalize(s) FROM reservoir_state ORDER BY g;
----

# combine_aggr across groups, including a NULL state
query I
SELECT finalize(combine_aggr(s)) FROM (
    SELECT reservoir_quantile(i, 0.5, 2000) EXPORT_STATE AS s FROM range(1, 500) t(i)
    UNION ALL
    SELECT reservoir_quantile(i, 0.5, 2000) EXPORT_STATE AS s FROM range(500, 1001) t(i)
    UNION ALL
    SELECT reservoir_quantile(i, 0.5, 2000) EXPORT_STATE AS s FROM (SELECT 1 AS i WHERE false) t
) t;
----
500

# sampling kicks in when the reservoir is smaller than the input - the result stays within the value range
query I
SELECT finalize(reservoir_quantile(i, 0.5, 100) EXPORT_STATE) BETWEEN 1 AND 10000 FROM range(1, 10001) t(i);
----
true
