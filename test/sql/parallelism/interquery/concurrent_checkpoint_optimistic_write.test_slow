# name: test/sql/parallelism/interquery/concurrent_checkpoint_optimistic_write.test_slow
# group: [interquery]

load __TEST_DIR__/concurrent_read_checkpoint_overwrite.db

statement ok
CREATE TABLE big_tbl AS SELECT i, concat('thisisalongstring', i)::VARCHAR s, FROM range(10_000_000) t(i);

statement ok
CHECKPOINT

# restart to ensure all blocks are unloaded
restart

statement ok
SET threads=1

statement ok
SET checkpoint_threshold='1TB'

statement ok
DELETE FROM big_tbl WHERE i%2=0 OR i//3=0

concurrentloop threadid 0 2

onlyif threadid=0
statement ok
CHECKPOINT

onlyif threadid=0
statement ok
INSERT INTO big_tbl SELECT random()::BIGINT, concat('thisisanotherlongstring', random()::BIGINT) FROM range(10_000_000);

onlyif threadid>0
statement ok
SELECT COUNT(*), SUM(i), SUM(strlen(s)), SUM(sleep_ms(case when i%943=0 then 1 else 0 end)), SUM(case when i%943=0 then 1 else 0 end) FROM big_tbl

endloop
